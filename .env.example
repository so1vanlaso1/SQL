# Copy to .env and edit as needed. All values are optional (sensible defaults exist).

# ---- Embedding ----
# auto = try the real model, fall back to hashing if unavailable.  st = force real model.  hashing = force fallback.
EMBEDDER=auto
EMBED_MODEL=ibm-granite/granite-embedding-311m-multilingual-r2

# ---- Retrieval knobs ----
TOP_K_CHUNKS=15
MAX_SEED_TABLES=6
MAX_EXPAND_TABLES=12
ROW_SAMPLE_LIMIT=10
SKILL_SAMPLE_LIMIT=3

# ---- Full RAG -> planner -> SQL pipeline ----
# none | llamacpp | ollama | openai
PIPELINE_LLM_BACKEND=none
SQL_DIALECT=sqlite
QUERY_TIMEOUT_SECONDS=30
MAX_RESULT_ROWS=500
RAW_SELECT_LIMIT=100
EXPLAIN_MAX_SCAN_ROWS=100000
PLANNER_REPAIR_ATTEMPTS=1
SQL_REPAIR_ATTEMPTS=1

# llama.cpp router mode. Start with:
# llama-server --models-dir ./models --models-max 1 --sleep-idle-seconds 300
LLAMACPP_BASE_URL=http://localhost:8888
LLAMACPP_API_KEY=
GEMMA_PLANNER_MODEL=gemma4-planner
QWEN_SQL_MODEL=qwen3.5-sql
GEMMA_PLANNER_HF_ID=unsloth/gemma-4-E4B-it-GGUF:UD-Q4_K_XL
QWEN_SQL_HF_ID=unsloth/Qwen3.5-9B-GGUF:UD-Q4_K_XL
LLAMA_MANUAL_LOAD=1
LLAMA_MANUAL_UNLOAD=1

# ---- Legacy single SQL LLM backend (kept for older experiments) ----
# none | ollama | openai | transformers
SQL_LLM_BACKEND=none

# ollama (local):  `ollama pull qwen2.5-coder:7b`
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# openai-compatible (OpenAI, DeepSeek, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# local HuggingFace coder model
HF_SQL_MODEL=Qwen/Qwen2.5-Coder-1.5B-Instruct
